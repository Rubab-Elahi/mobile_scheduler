# Ignore installed packages in service folders
# (Keep only the handler and requirements)
services/*/bin/
services/*/lib/
services/*/include/
services/*/share/
services/*/*.dist-info/
services/*/*.egg-info/

# Specific large libraries installed via pip --target
services/**/openai/
services/**/google/
services/**/google_api_python_client*/
services/**/httpx/
services/**/httpcore/
services/**/pydantic/
services/**/boto3/
services/**/botocore/
services/**/urllib3/
services/**/certifi/
services/**/charset_normalizer/
services/**/idna/
services/**/s3transfer/
services/**/jmespath/
services/**/dateutil/
services/**/typing_extensions*/

